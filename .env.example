# LangGraph Workshop Environment Variables

# LLM Provider API Keys (choose at least one)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LangSmith (for observability - required for Day 5)
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=langgraph-workshop

# Enable tracing (optional, useful for debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Workshop Configuration
WORKSHOP_TRACK=python  # or typescript
WORKSHOP_DAY=1
